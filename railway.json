{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  },
  "environments": {
    "production": {
      "MULTIPOST_API_KEY": "",
      "NEXT_PUBLIC_SITE_URL": "https://aishangye-production.up.railway.app"
    }
  }
}
