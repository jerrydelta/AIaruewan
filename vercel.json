{
  "version": 2,
  "name": "handmade-ai-tools",
  "builds": [
    {
      "src": "builds/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "builds/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "builds/**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/builds/$1"
    },
    {
      "src": "/",
      "dest": "/builds/20260718/index.html"
    }
  ],
  "github": {
    "enabled": true,
    "autoAlias": true
  }
}
